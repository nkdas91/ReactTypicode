{
  "ci": {
    "collect": {
      "url": ["http://localhost:4173"],
      "startServerCommand": "npm run preview"
    },

    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.8
          }
        ],

        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    }
  }
}
